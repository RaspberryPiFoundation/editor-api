{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run test file (RSpec)",
      "type": "shell",
      "command": "./bin/rspec",
      "args": [
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run test at current line (RSpec)",
      "type": "shell",
      "command": "./bin/rspec",
      "args": [
        "${file}:${lineNumber}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
