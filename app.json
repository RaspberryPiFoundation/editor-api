{
  "name": "editor-api",
  "scripts": {
     "postdeploy": "bin/rails db:seed"
  },
  "env": {
    "BYPASS_OAUTH": {
      "value": "true"
    },
    "HEROKU_APP_NAME": {
      "required": true
    },
    "RAILS_ENV": {
      "required": true
    },
    "SALESFORCE_ENABLED": {
      "value": "false"
    },
    "SENTRY_CURRENT_ENV": {
      "value": "review"
    }
  },
  "formation": {
    "web": {
      "quantity": 1
    }
  },
  "addons": [
    "heroku-postgresql:essential-0"
  ],
  "buildpacks": [
    {
      "url": "heroku/ruby"
    }
  ]
}
